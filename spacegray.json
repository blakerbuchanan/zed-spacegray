{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Spacegray",
  "author": "Ported to Zed by Blake Buchanan (based on doom-spacegrey by teesloane)",
  "themes": [
    {
      "name": "Spacegray",
      "appearance": "dark",
      "style": {
        "accents": [
          "#8FA1B3ff",
          "#A3BE8Cff",
          "#ECBE7Bff",
          "#D08770ff",
          "#b48eadff",
          "#4db5bdff"
        ],

        "background": "#2b303bff",
        "elevated_surface.background": "#232830ff",
        "surface.background": "#232830ff",
        "panel.background": "#232830ff",
        "panel.focused_border": "#4f5b66ff",
        "pane.focused_border": "#8FA1B366",

        "border": "#2F3237ff",
        "border.variant": "#232830ff",
        "border.focused": "#8FA1B3ff",
        "border.selected": "#8FA1B366",
        "border.transparent": "#00000000",
        "border.disabled": "#2F3237ff",

        "element.background": "#2F3237ff",
        "element.hover": "#3a3f4bff",
        "element.active": "#4f5b66ff",
        "element.selected": "#4f5b6699",
        "element.disabled": "#232830ff",

        "ghost_element.background": "#00000000",
        "ghost_element.hover": "#2F323766",
        "ghost_element.active": "#4f5b6666",
        "ghost_element.selected": "#4f5b6666",
        "ghost_element.disabled": "#232830ff",

        "drop_target.background": "#8FA1B326",

        "editor.background": "#2b303bff",
        "editor.foreground": "#c0c5ceff",
        "editor.gutter.background": "#2b303bff",
        "editor.active_line.background": "#2F3237ff",
        "editor.highlighted_line.background": "#333840ff",
        "editor.line_number": "#4f5b66ff",
        "editor.active_line_number": "#9ca0a4ff",
        "editor.invisible": "#4f5b66ff",
        "editor.wrap_guide": "#2F3237ff",
        "editor.active_wrap_guide": "#4f5b66ff",
        "editor.document_highlight.read_background": "#8FA1B326",
        "editor.document_highlight.write_background": "#8FA1B340",
        "editor.subheader.background": "#232830ff",

        "text": "#c0c5ceff",
        "text.muted": "#9ca0a4ff",
        "text.placeholder": "#65737Eff",
        "text.disabled": "#4f5b66ff",
        "text.accent": "#8FA1B3ff",

        "icon": "#9ca0a4ff",
        "icon.muted": "#65737Eff",
        "icon.disabled": "#4f5b66ff",
        "icon.placeholder": "#65737Eff",
        "icon.accent": "#8FA1B3ff",
        "icon.background": "#2b303bff",
        "icon.border": "#2F3237ff",

        "link_text.hover": "#8FA1B3ff",

        "status_bar.background": "#1B2229ff",
        "title_bar.background": "#1c1f24ff",
        "title_bar.inactive_background": "#1B2229ff",
        "toolbar.background": "#2b303bff",
        "tab_bar.background": "#232830ff",
        "tab.inactive_background": "#232830ff",
        "tab.active_background": "#2b303bff",

        "search.match_background": "#D0877040",

        "scrollbar.thumb.background": "#4f5b66cc",
        "scrollbar.thumb.hover_background": "#65737Ecc",
        "scrollbar.thumb.border": "#4f5b66ff",
        "scrollbar.track.background": "#00000000",
        "scrollbar.track.border": "#2F3237ff",

        "terminal.background": "#1B2229ff",
        "terminal.foreground": "#c0c5ceff",
        "terminal.bright_foreground": "#DFDFDFff",
        "terminal.dim_foreground": "#73797eff",
        "terminal.ansi.black": "#1B2229ff",
        "terminal.ansi.bright_black": "#4f5b66ff",
        "terminal.ansi.red": "#BF616Aff",
        "terminal.ansi.bright_red": "#BF616Aff",
        "terminal.ansi.green": "#A3BE8Cff",
        "terminal.ansi.bright_green": "#A3BE8Cff",
        "terminal.ansi.yellow": "#ECBE7Bff",
        "terminal.ansi.bright_yellow": "#ECBE7Bff",
        "terminal.ansi.blue": "#8FA1B3ff",
        "terminal.ansi.bright_blue": "#8FA1B3ff",
        "terminal.ansi.magenta": "#b48eadff",
        "terminal.ansi.bright_magenta": "#b48eadff",
        "terminal.ansi.cyan": "#4db5bdff",
        "terminal.ansi.bright_cyan": "#46D9FFff",
        "terminal.ansi.white": "#c0c5ceff",
        "terminal.ansi.bright_white": "#DFDFDFff",

        "error": "#BF616Aff",
        "error.background": "#BF616A20",
        "error.border": "#BF616A40",

        "warning": "#ECBE7Bff",
        "warning.background": "#ECBE7B20",
        "warning.border": "#ECBE7B40",

        "info": "#8FA1B3ff",
        "info.background": "#8FA1B320",
        "info.border": "#8FA1B340",

        "success": "#A3BE8Cff",
        "success.background": "#A3BE8C20",
        "success.border": "#A3BE8C40",

        "hint": "#65737Eff",
        "hint.background": "#2F3237ff",
        "hint.border": "#4f5b6600",

        "predictive": "#65737Eff",
        "predictive.background": "#2F323799",
        "predictive.border": "#2F323700",

        "created": "#A3BE8Cff",
        "created.background": "#A3BE8C20",
        "created.border": "#A3BE8C40",

        "modified": "#D08770ff",
        "modified.background": "#D0877020",
        "modified.border": "#D0877040",

        "deleted": "#BF616Aff",
        "deleted.background": "#BF616A20",
        "deleted.border": "#BF616A40",

        "conflict": "#D08770ff",
        "conflict.background": "#D0877020",
        "conflict.border": "#D0877040",

        "hidden": "#65737Eff",
        "hidden.background": "#23283000",
        "hidden.border": "#2F323740",

        "ignored": "#4f5b66ff",
        "ignored.background": "#2b303b00",
        "ignored.border": "#2F323700",

        "renamed": "#8FA1B3ff",
        "renamed.background": "#8FA1B320",
        "renamed.border": "#8FA1B340",

        "players": [
          { "cursor": "#D08770ff", "background": "#D08770ff", "selection": "#4f5b6666" },
          { "cursor": "#A3BE8Cff", "background": "#A3BE8Cff", "selection": "#A3BE8C40" },
          { "cursor": "#ECBE7Bff", "background": "#ECBE7Bff", "selection": "#ECBE7B40" },
          { "cursor": "#8FA1B3ff", "background": "#8FA1B3ff", "selection": "#8FA1B340" },
          { "cursor": "#b48eadff", "background": "#b48eadff", "selection": "#b48ead40" },
          { "cursor": "#4db5bdff", "background": "#4db5bdff", "selection": "#4db5bd40" },
          { "cursor": "#BF616Aff", "background": "#BF616Aff", "selection": "#BF616A40" },
          { "cursor": "#9ca0a4ff", "background": "#9ca0a4ff", "selection": "#9ca0a440" }
        ],

        "syntax": {
          "attribute": { "color": "#D08770ff" },
          "boolean": { "color": "#D08770ff" },
          "comment": { "color": "#65737Eff", "font_style": "italic" },
          "comment.doc": { "color": "#73797eff", "font_style": "italic" },
          "constant": { "color": "#D08770ff" },
          "constructor": { "color": "#8FA1B3ff" },
          "embedded": { "color": "#c0c5ceff" },
          "emphasis": { "color": "#b48eadff", "font_style": "italic" },
          "emphasis.strong": { "color": "#b48eadff", "font_weight": 700 },
          "enum": { "color": "#D08770ff" },
          "function": { "color": "#8FA1B3ff" },
          "function.builtin": { "color": "#4db5bdff" },
          "function.definition": { "color": "#8FA1B3ff" },
          "hint": { "color": "#65737Eff" },
          "keyword": { "color": "#b48eadff" },
          "label": { "color": "#ECBE7Bff" },
          "link_text": { "color": "#8FA1B3ff" },
          "link_uri": { "color": "#4db5bdff" },
          "number": { "color": "#D08770ff" },
          "operator": { "color": "#c0c5ceff" },
          "predictive": { "color": "#65737Eff", "font_style": "italic" },
          "preproc": { "color": "#b48eadff" },
          "primary": { "color": "#8FA1B3ff" },
          "property": { "color": "#A3BE8Cff" },
          "punctuation": { "color": "#73797eff" },
          "punctuation.bracket": { "color": "#73797eff" },
          "punctuation.delimiter": { "color": "#73797eff" },
          "punctuation.list_marker": { "color": "#8FA1B3ff" },
          "punctuation.special": { "color": "#4db5bdff" },
          "string": { "color": "#A3BE8Cff" },
          "string.escape": { "color": "#4db5bdff" },
          "string.regex": { "color": "#4db5bdff" },
          "string.special": { "color": "#4db5bdff" },
          "string.special.symbol": { "color": "#4db5bdff" },
          "tag": { "color": "#BF616Aff" },
          "text.literal": { "color": "#A3BE8Cff" },
          "title": { "color": "#8FA1B3ff", "font_weight": 700 },
          "type": { "color": "#ECBE7Bff" },
          "type.builtin": { "color": "#ECBE7Bff" },
          "type.super": { "color": "#ECBE7Bff" },
          "variable": { "color": "#BF616Aff" },
          "variable.builtin": { "color": "#D08770ff" },
          "variable.member": { "color": "#A3BE8Cff" },
          "variable.parameter": { "color": "#c0c5ceff" },
          "variant": { "color": "#D08770ff" }
        }
      }
    }
  ]
}
