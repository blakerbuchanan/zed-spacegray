// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "Terminal",
    "unbind": {
      "ctrl-shift-space": "terminal::ToggleViMode"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-c ctrl-t": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-`": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-c o p": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-b": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "enter": "project_panel::Open"
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "unbind": {
      "space": "project_panel::Open"
    }
  },
  {
    "bindings": {
      "ctrl-c p f": "file_finder::Toggle"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-c p": "project_panel::ToggleFocus"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-shift-e": "project_panel::ToggleFocus"
    }
  }
]
